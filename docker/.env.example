# Copy to .env and edit if needed:  cp .env.example .env
#
# Hostname the stack serves on. Leave as localhost to match Vodou's defaults
# (Vodou opens https://localhost/searxng and trusts localhost certificates).
SEARXNG_HOSTNAME=localhost

# SearXNG worker processes. 2 is fine for a single user; raise for a shared
# instance.
SEARXNG_WORKERS=2

# Model auto-pulled for AI summaries when you start with `--profile ai`.
# Any Ollama model tag works (e.g. llama3.2, mistral, gemma3:4b).
OLLAMA_MODEL=llama3.2
